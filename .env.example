# Optional: overrides secret key (auto-generated if not set)
SECRET_KEY=your-secret-key-here

# Optional: directory for database and uploaded files (defaults to app directory)
DATA_DIR=/data

# Optional: set to "true" for development
FLASK_DEBUG=false

# Optional: override port (default 5000)
PORT=5000

# All API keys (Freshdesk, Anthropic, Jira, Google, Notion) are
# configured in the app's Settings page and stored in the database.
