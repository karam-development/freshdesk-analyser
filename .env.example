# ── Flask ────────────────────────────────────────────────────────────────────
# Flask session secret — generate a strong random value for production
SECRET_KEY=change-me-in-production

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory for the SQLite database and uploaded files.
# On Render, point this at the persistent disk mount (e.g. /data).
# Defaults to the app directory when not set.
DATA_DIR=/data

# ── Freshdesk ────────────────────────────────────────────────────────────────
FRESHDESK_API_KEY=
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_GROUP_ID=

# ── AI Provider (new unified path) ───────────────────────────────────────────
# Provider used by the LLM router for all routed agents.
# Supported values: anthropic | openai
LLM_PROVIDER=anthropic

# API key for the selected provider.
# This is the key read by LLMRouter — it does NOT fall back to ANTHROPIC_API_KEY.
LLM_API_KEY=

# Optional: base URL override (e.g. for OpenAI-compatible endpoints)
LLM_BASE_URL=

# Optional: override the fast/cheap model used by lightweight agents
LLM_FAST_MODEL=

# Optional: override the main/capable model used by analysis agents
LLM_MAIN_MODEL=

# ── Legacy Anthropic key ─────────────────────────────────────────────────────
# Kept for the old direct Anthropic code path only.
# The LLM router (LLMRouter) does NOT read this key — configure LLM_API_KEY instead.
ANTHROPIC_API_KEY=

# ── Jira (optional) ──────────────────────────────────────────────────────────
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_PROJECT=LUX
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Google Workspace (optional) ──────────────────────────────────────────────
# Full JSON content of the service account key file (single-line or multi-line)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# ── Notion (optional) ────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── Misc ─────────────────────────────────────────────────────────────────────
APP_ENV=production
DATABASE_URL=

# ── Dev overrides ────────────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5000
